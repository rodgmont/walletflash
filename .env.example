# ═══════════════════════════════════════════════════════════════════
#  Flash Wallet — variables de entorno
#  Copia este archivo a .env.local y rellena los valores.
#  Documentación Flash API: https://docs.bitcoinflash.xyz
# ═══════════════════════════════════════════════════════════════════

# ── Base URL de la API Flash ────────────────────────────────────────
# Staging (recomendado para desarrollo/hackathon):
NEXT_PUBLIC_FLASH_API=https://staging.bitcoinflash.xyz/api/v1
# Producción (cuando tengas acceso real):
# NEXT_PUBLIC_FLASH_API=https://api.bitcoinflash.xyz/api/v1

# ── Autenticación (elige UNO de los dos métodos) ────────────────────

# MÉTODO A — Staging User ID (MÁS FÁCIL para el hackathon, solo staging)
# Pasos para obtenerlo:
#   1. Registrar cuenta en staging:
#      curl -X POST https://staging.bitcoinflash.xyz/api/v1/auth/register \
#        -H "Content-Type: application/json" \
#        -d '{"name":"Tu Nombre","email":"tu@email.com","password":"pass1234","password_confirmation":"pass1234","whatsapp":"+22912345678","country":"BJ"}'
#   2. Verificar OTP que llega al email:
#      curl -X POST https://staging.bitcoinflash.xyz/api/v1/auth/verify-otp \
#        -H "Content-Type: application/json" \
#        -d '{"email":"tu@email.com","otp":"123456"}'
#   3. Copiar el campo "id" del usuario que aparece en la respuesta de registro.
FLASH_STAGING_USER_ID=

# MÉTODO B — JWT Bearer Token (producción o staging)
# Pasos para obtenerlo:
#   1. Haz login con tu cuenta registrada:
#      curl -X POST https://staging.bitcoinflash.xyz/api/v1/auth/login \
#        -H "Content-Type: application/json" \
#        -d '{"email":"tu@email.com","password":"pass1234"}'
#   2. Copia el campo data.token de la respuesta.
#   Nota: el JWT expira en 60 minutos. Renuévalo con POST /api/v1/auth/refresh.
FLASH_API_SECRET=

# ── Tasa de conversión XOF/sat ──────────────────────────────────────
# Flash usa XOF como unidad de amount en la API.
# Valor por defecto: 0.55 (≈ 1 BTC = 55 000 000 XOF).
# Ajusta con la tasa real si la tienes disponible.
# FLASH_XOF_PER_SAT=0.55

# ── Webhook de pagos Lightning ──────────────────────────────────────
# Secreto para POST /api/webhooks/lightning-payment (header x-flash-webhook-secret).
# Tu nodo / proveedor LN debe enviar este header al notificar un pago liquidado.
LIGHTNING_WEBHOOK_SECRET=any-random-secret-here

# ── CORS para el widget CDN ─────────────────────────────────────────
# Origen permitido en respuestas LNURL (por defecto *).
# En producción restringe al dominio de tu tienda.
# CDN_WIDGET_ALLOW_ORIGIN=https://tutienda.com
