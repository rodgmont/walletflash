# Copia a .env.local y rellena los valores.

# Base de la API Flash (documentación: https://docs.bitcoinflash.xyz )
NEXT_PUBLIC_FLASH_API=https://api.bitcoinflash.xyz/api/v1

# Token Bearer para el endpoint de venta (Transactions / sell). Sin esto, el servidor usa modo simulado.
FLASH_API_SECRET=

# JSON opcional fusionado en el cuerpo del POST /transactions/sell si el esquema oficial difiere.
# Ejemplo: {"payout_network":"MOMO_TOGO"}
# FLASH_SELL_EXTRA_JSON=

# Secreto para POST /api/webhooks/lightning-payment (cabecera x-flash-webhook-secret).
LIGHTNING_WEBHOOK_SECRET=

# Origen permitido para CORS en respuestas LNURL (por defecto *). En producción usa tu dominio del checkout.
# CDN_WIDGET_ALLOW_ORIGIN=https://tutienda.com
